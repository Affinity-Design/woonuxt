# =============================================================================
# ENVIRONMENT: TEST  ←  uncomment LIVE block + comment this block to switch
# =============================================================================

# -- WordPress / WooCommerce connection ---------------------------------------
GQL_HOST=https://test.yourdomain.com/graphql
BASE_URL=https://test.yourdomain.com
APP_HOST=https://test.yourdomain.com
FRONTEND_URL=https://test.yourdomain.ca
NUXT_IMAGE_DOMAINS=https://test.yourdomain.com
WC_CONSUMER_KEY=ck_your_test_consumer_key
WC_CONSUMER_SECRET=cs_your_test_consumer_secret
WP_ADMIN_USERNAME=your-test-wp-admin-username
WP_ADMIN_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# -- Stripe (test keys) -------------------------------------------------------
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
NUXT_STRIPE_SECRET_KEY=sk_test_your_key

# =============================================================================
# ENVIRONMENT: LIVE  ←  uncomment this block + comment TEST block above
# =============================================================================

# -- WordPress / WooCommerce connection ---------------------------------------
#GQL_HOST=https://yourdomain.com/graphql
#BASE_URL=https://yourdomain.com
#APP_HOST=https://yourdomain.com
#FRONTEND_URL=https://yourdomain.ca
#NUXT_IMAGE_DOMAINS=https://yourdomain.com
#WC_CONSUMER_KEY=ck_your_live_consumer_key
#WC_CONSUMER_SECRET=cs_your_live_consumer_secret
#WP_ADMIN_USERNAME=your-live-wp-admin-username
#WP_ADMIN_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# -- Stripe (live keys) -------------------------------------------------------
#NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
#NUXT_STRIPE_SECRET_KEY=sk_live_your_key

# =============================================================================
# CLOUDFLARE  (same for both environments)
# =============================================================================
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_KV_NAMESPACE_ID_CACHE=your_kv_cache_namespace_id
CF_KV_NAMESPACE_ID_SCRIPT_DATA=your_kv_script_data_namespace_id

# =============================================================================
# PAYMENTS & INTEGRATIONS
# =============================================================================
NUXT_HELCIM_API_TOKEN=your_helcim_api_token
SENDGRID_API_KEY=SG.your_sendgrid_key
# GOOGLE_AI_API_KEY is also used as GEMINI_API_KEY by wordpress/scripts/lib/gemini.js
# (lib/gemini.js accepts either GEMINI_API_KEY or GOOGLE_AI_API_KEY)
GOOGLE_AI_API_KEY=your_google_ai_key
GEMINI_API_KEY=your_google_ai_key  # alias — can be same value as GOOGLE_AI_API_KEY
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret

# =============================================================================
# EMAIL
# =============================================================================
SENDING_EMAIL=noreply@yourdomain.com
RECEIVING_EMAIL=info@yourdomain.com

# =============================================================================
# SECURITY
# =============================================================================
REVALIDATION_SECRET=generate_a_random_secret_here
TURNSTYLE_SITE_KEY=your_turnstile_site_key
TURNSTYLE_SECRET_KEY=your_turnstile_secret_key

# =============================================================================
# BUILD & CACHE SETTINGS
# =============================================================================
NODE_ENV=production
LIMIT_PRODUCTS=false
MAX_PRODUCTS=2000
NUXT_PUBLIC_BUILD_TIME_EXCHANGE_RATE=1.38
EXCHANGE_RATE_API_KEY=null
RUN_CACHE_WARMING=true
WARM_CRITICAL_ONLY=false
WOOCOMMERCE_CURRENCY=CAD